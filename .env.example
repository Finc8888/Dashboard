# --- Auth Gateway ---
JWT_SECRET=your_super_secret_jwt_key_change_me
AUTH_DB_USER=appuser
AUTH_DB_PASSWORD=secret
AUTH_DB_NAME=authdb
AUTH_DB_ROOT_PASSWORD=rootsecret

# --- Job Statistics ---
JOBS_DB_USER=jobuser
JOBS_DB_PASSWORD=jobpassword
JOBS_DB_NAME=job_stats
JOBS_DB_ROOT_PASSWORD=rootpassword

# --- Gladys Chat ---
CHAT_DB_USER=chat_user
CHAT_DB_PASSWORD=chat_password
CHAT_DB_NAME=chat
CHAT_DB_ROOT_PASSWORD=rootpassword

# --- Sketchbook ---
SKETCH_DB_USER=sketchuser
