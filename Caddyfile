{
    auto_https off
}

:80 {
    # -- Auth endpoints (public, no forward_auth) --
    handle /api/auth/* {
        reverse_proxy auth-gateway:8080
    }

    handle /api/health {
        reverse_proxy auth-gateway:8080
    }

    # -- Admin API (protected by forward_auth + backend middleware) --
    handle /api/admin/* {
        forward_auth auth-gateway:8080 {
            uri /api/auth/verify
            copy_headers X-Auth-User X-Auth-Role X-Auth-Username X-Auth-Permissions
        }
        reverse_proxy auth-gateway:8080
    }

    # -- Admin Panel UI --
    handle /admin/* {
        forward_auth auth-gateway:8080 {
            uri /api/auth/verify
            copy_headers X-Auth-User X-Auth-Role X-Auth-Username X-Auth-Permissions
        }
        uri strip_prefix /admin
        reverse_proxy auth-admin:80
    }
    handle /admin {
        redir /admin/ permanent
    }

    # -- Blog (wrapper with Dashboard link) --
    handle /blog {
        redir /blog/ permanent
    }
    handle /blog/ {
        forward_auth auth-gateway:8080 {
            uri /api/auth/verify
            copy_headers X-Auth-User X-Auth-Role X-Auth-Username X-Auth-Permissions
        }
        root * /srv/www
        rewrite * /blog-wrapper.html
        file_server
    }
    # -- Blog raw content (inside iframe) --
    handle /blog-raw/* {
        forward_auth auth-gateway:8080 {
            uri /api/auth/verify
            copy_headers X-Auth-User X-Auth-Role X-Auth-Username X-Auth-Permissions
        }
        uri strip_prefix /blog-raw
        reverse_proxy gladys-blog:443 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }
    handle /blog-raw {
        redir /blog-raw/ permanent
    }

    # -- Job Statistics --
    handle /jobs/api/* {
        forward_auth auth-gateway:8080 {
            uri /api/auth/verify
            copy_headers X-Auth-User X-Auth-Role X-Auth-Username X-Auth-Permissions
        }
        uri strip_prefix /jobs
        reverse_proxy job-stats-api:8081
    }
    handle /jobs/* {
        forward_auth auth-gateway:8080 {
            uri /api/auth/verify
            copy_headers X-Auth-User X-Auth-Role X-Auth-Username X-Auth-Permissions
        }
        uri strip_prefix /jobs
        reverse_proxy job-stats-frontend:3000
    }
    handle /jobs {
        redir /jobs/ permanent
    }

    # -- Gladys Chat --
    handle /chat/api/* {
        forward_auth auth-gateway:8080 {
            uri /api/auth/verify
            copy_headers X-Auth-User X-Auth-Role X-Auth-Username X-Auth-Permissions
        }
        uri strip_prefix /chat
        reverse_proxy gladys-chat-api:8082
    }
    handle /chat/ws {
        forward_auth auth-gateway:8080 {
            uri /api/auth/verify
            copy_headers X-Auth-User X-Auth-Role X-Auth-Username X-Auth-Permissions
        }
        uri strip_prefix /chat
        reverse_proxy gladys-chat-api:8082
    }
    handle /chat/* {
        forward_auth auth-gateway:8080 {
            uri /api/auth/verify
            copy_headers X-Auth-User X-Auth-Role X-Auth-Username X-Auth-Permissions
        }
        uri strip_prefix /chat
        reverse_proxy gladys-chat-frontend:80
    }
    handle /chat {
        redir /chat/ permanent
    }

    # -- Dashboard (default) --
    handle {
        reverse_proxy dashboard:80
    }

    encode gzip zstd

    header {
        X-Content-Type-Options "nosniff"
    }
    header /blog-raw/* {
        X-Frame-Options "SAMEORIGIN"
    }

    log {
        output stdout
        format console
    }
}
